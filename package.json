    "tags:summarize": "scripts/player-tag-tests/summarize-probes.py"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^5.1.4",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "smol-toml": "^1.7.0",
    "vite": "^8.1.4"
  },
  "devDependencies": {
    "@types/node": "^24.10.10",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "tsx": "^4.21.0",
    "typescript": "^7.0.2"
  },
  "allowScripts": {
    "esbuild@0.28.1": true,
    "fsevents@2.3.3": true
  }
}
