{
  "name": "metadata-editor",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:server": "tsx watch server/index.ts",
    "test": "node --import tsx --test tests/*.test.ts",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
